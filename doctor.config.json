{
  "$schema": "https://react.doctor/schema/config.json",
  "deadCode": false,
  "ignore": {
    "files": ["convex/**"],
    "overrides": [
      {
        "files": ["src/components/ui/player-link.tsx"],
        "rules": ["react-doctor/prefer-tag-over-role"]
      },
      {
        "files": ["package.json"],
        "rules": ["socket/low-supply-chain-score"]
      }
    ]
  },
  "rules": {
    "react-doctor/no-flush-sync": "off",
    "react-doctor/no-document-start-view-transition": "off",
    "react-doctor/no-chain-state-updates": "off"
  }
}
